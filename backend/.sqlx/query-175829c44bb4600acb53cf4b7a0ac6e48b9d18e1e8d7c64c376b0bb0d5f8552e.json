  "query": "\n        SELECT\n            prev.id,\n            prev.number,\n            prev.election_id,\n            prev.status,\n            prev.location,\n            prev.start_date_time\n        FROM committee_sessions AS c\n        JOIN committee_sessions AS prev ON c.election_id = prev.election_id AND c.number = prev.number + 1\n        WHERE c.id = ?\n        ",
