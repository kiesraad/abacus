  "query": "\n        SELECT\n            de.id AS data_entry_id,\n            sc.id,\n            sc.number,\n            sc.name,\n            sc.category,\n            de.state AS \"state!: Json<DataEntryStatus>\"\n        FROM sub_committees AS sc\n        JOIN data_entries AS de ON de.id = sc.data_entry_id\n        WHERE sc.committee_session_id = $1\n        ",
