{
  "db_name": "SQLite",
  "query": "SELECT\n            u.id,\n            u.username,\n            u.fullname,\n            u.password_hash,\n            u.needs_password_change,\n            u.role,\n            u.last_activity_at,\n            (\n                SELECT COUNT(*)\n                FROM sessions s\n                WHERE s.user_id = u.id\n                    AND s.expires_at > datetime($1)\n            ) > 0 as \"is_logged_in: bool\",\n            u.updated_at,\n            u.created_at\n        FROM users u\n        WHERE ($2 IS NULL OR u.role = $2)\n        ",
